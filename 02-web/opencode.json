{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "WEB_AGENTS.md",
    "WEB_IMPLEMENTATION_PLAN.md",
    "WEB_SESSION_MANIFEST.md"
  ],
  "mcp": {
    "urbania-db": {
      "type": "local",
      "command": [
        "powershell",
        "-NoProfile",
        "-File",
        "../.opencode/start-db-mcp.ps1"
      ],
      "enabled": true
    },
    "codebase-memory": {
      "type": "local",
      "command": [
        "codebase-memory-mcp"
      ],
      "env": {
        "CODEBASE_MEMORY_PROJECT": "urbania-web"
      },
      "enabled": true
    }
  }
}
